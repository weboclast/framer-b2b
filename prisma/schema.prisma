generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(OWNER)
  storeId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  password  String?
  store     Store?   @relation("StoreOwner")
}

model Store {
  id               String         @id @default(nanoid(12))
  name             String
  businessLocation String?
  currency         String         @default("USD")
  taxPercent       Float          @default(0)
  ownerId          String         @unique
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  emailSettings    EmailSettings?
  rfqs             RFQ[]
  shippingRules    ShippingRule[]
  discounts        Discount[]
  owner            User           @relation("StoreOwner", fields: [ownerId], references: [id])
}

model ShippingRule {
  id          String    @id @default(cuid())
  storeId     String
  countryCode String?
  isDefault   Boolean   @default(false)
  flatRate    Float     @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model EmailSettings {
  id                  String   @id @default(cuid())
  storeId             String   @unique
  senderAddress       String?
  replyTo             String?
  internalRecipient   String?
  confirmationSubject String?
  confirmationBody    String?
  notificationSubject String?
  notificationBody    String?
  quoteSubject        String?
  quoteBody           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model RFQ {
  id                      String          @id @default(uuid())
  storeId                 String
  status                  RFQStatus       @default(PENDING)
  subtotal                Float           @default(0)
  tax                     Float           @default(0)
  shipping                Float           @default(0)
  total                   Float           @default(0)
  customerName            String
  customerEmail           String
  companyName             String?
  phone                   String?
  addressCity             String?
  addressCountry          String?
  addressPostal           String?
  addressState            String?
  addressLines            Json?
  additionalCustomerData  Json?
  rawPayload              Json?
  consumerUserId          String?
  confirmationEmailStatus EmailStatus     @default(PENDING)
  deletedAt               DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  quoteNotes              QuoteNote[]
  store                   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  consumer                ConsumerUser?   @relation(fields: [consumerUserId], references: [id])
  items                   RFQItem[]
  statusHistory           StatusHistory[]

  @@index([storeId])
  @@index([status])
  @@index([customerEmail])
}

model RFQItem {
  id             String   @id @default(cuid())
  rfqId          String
  productId      String?
  productName    String
  imageUrl       String?
  unitPrice      Float
  quantity       Int
  lineTotal      Float
  additionalData Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  rfq            RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model StatusHistory {
  id        String    @id @default(cuid())
  rfqId     String
  status    RFQStatus
  note      String?
  changedBy String?
  changedAt DateTime  @default(now())
  rfq       RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model QuoteNote {
  id          String      @id @default(cuid())
  rfqId       String
  sentAt      DateTime    @default(now())
  messageBody String
  sentBy      String?
  emailStatus EmailStatus @default(PENDING)
  rfq         RFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model ConsumerUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rfqs      RFQ[]
}

model Discount {
  id          String       @id @default(cuid())
  storeId     String
  code        String
  type        DiscountType
  value       Float
  minSubtotal Float        @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
  @@index([storeId])
}

enum UserRole {
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum RFQStatus {
  PENDING
  QUOTED
  ACCEPTED
  CLOSED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}
